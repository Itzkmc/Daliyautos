{
  "entities": {
    "Car": {
      "title": "Car",
      "description": "A vehicle listing on DailyAutos",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the car (e.g. Tesla Model 3)" },
        "year": { "type": "number", "description": "The manufacturing year" },
        "type": { "type": "string", "enum": ["EV", "Petrol", "Hybrid"], "description": "The engine type" },
        "image": { "type": "string", "format": "uri", "description": "URL to the car image" },
        "dealerName": { "type": "string", "description": "Name of the dealership" },
        "isVerified": { "type": "boolean", "description": "Whether the listing is verified" },
        "priceRange": { "type": "string", "description": "Optional price range (usually empty per user request)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the listing was created" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the listing was last updated" }
      },
      "required": ["name", "year", "type", "image", "dealerName"]
    },
    "User": {
      "title": "User",
      "description": "A user of the platform (Admin or Dealer)",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "dealer", "user"] },
        "displayName": { "type": "string" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/cars/{carId}": {
      "schema": "Car",
      "description": "Collection of car listings"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    }
  }
}
